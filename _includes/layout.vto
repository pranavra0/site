<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="view-transition" content="same-origin" />
  <title>{{ title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="/assets/style.css">
</head>
<body>
  <div class="page-wrapper">
    <header>
      <nav>
        <a href="/" class="{{ if url == '/' }}active{{ /if }}">home</a>
        <a href="/projects/" class="{{ if url == '/projects/' || url.startsWith('/projects/') }}active{{ /if }}">projects</a>
      </nav>
    </header>

    <main>
      {{ content }}
    </main>

    <footer>
      <div class="footer-name">PP</div>
    </footer>
  </div>

  <script>
    // Random slant for email hover on each entry
    (function() {
      const email = document.querySelector('h2 a.caution-hover');
      if (!email) return;
      email.addEventListener('mouseenter', function() {
        const deg = (Math.random() * 10 - 5).toFixed(2);
        this.style.setProperty('--slant', deg + 'deg');
      });
    })();
  </script>
</body>
</html>
